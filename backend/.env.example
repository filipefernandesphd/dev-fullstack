NODE_ENV=
PORT=

# IA real: Google Gemini (free tier) via endpoint compatível com OpenAI
# AI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# AI_MODEL=gemini-2.0-flash
# Ao usar Ollama
# http://ollama:11434/v1/chat/completions se o backend estiver no Docker
# http://localhost:11434/v1/chat/completions se o backend NÃO estiver no Docker
AI_API_URL=
AI_MODEL=
AI_API_KEY=
# Tempo máximo (ms) de espera pela resposta do provedor (opcional, padrão 30000)
AI_TIMEOUT_MS=

# Conexão com o MongoDB. Vazio = persistência desligada (não derruba a requisição)
MONGO_URL=

CORS_ORIGIN=
