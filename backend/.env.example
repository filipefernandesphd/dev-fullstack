NODE_ENV=
PORT=

AI_API_KEY=
AI_MODEL=
# Provedores compatíveis com o padrão Chat Completions (OpenAI):
#
# Google Gemini (free tier) — recomendado:
#   AI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
#   AI_MODEL=gemini-2.0-flash
#
# Ollama (local):
#   http://ollama:11434/v1/chat/completions se o backend estiver no Docker
#   http://localhost:11434/v1/chat/completions se o backend NÃO estiver no Docker
AI_API_URL=

CORS_ORIGIN=

# URL de conexão com o MongoDB (opcional em desenvolvimento/testes).
# Se ausente, a persistência do plano final é apenas registrada em log e ignorada.
#   Local via Docker Compose: mongodb://mongodb:27017/meuplanoai
#   Produção (Atlas): mongodb+srv://<usuario>:<senha>@<cluster>/meuplanoai
MONGO_URL=
